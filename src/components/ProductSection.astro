---
/**
 * Product Section
 * Full product display: image, details, specs, and React ProductSelector island.
 */
import ProductSelector from "./ProductSelector";
---

<section id="product" class="section bg-white">
  <div class="container-content">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">
      <!-- Left: Product Image -->
      <div class="fade-in sticky top-24">
        <!-- Main product image -->
        <div class="relative aspect-square rounded-3xl bg-neutral-50 border border-neutral-100 overflow-hidden" id="main-product-image">
          <img
            src="/images/product/product-black-views.jpg"
            alt="HAILTH Tactical Metal Hook Elastic Belt - Black"
            class="w-full h-full object-cover"
            loading="eager"
          />
        </div>

        <!-- Thumbnail strip -->
        <div class="mt-4 grid grid-cols-4 gap-3">
          {[
            { src: "/images/product/product-black-views.jpg", alt: "Product views" },
            { src: "/images/product/buckle-closeup-pair.jpg", alt: "Buckle closeup" },
            { src: "/images/product/lifestyle-worn-front.jpg", alt: "Belt worn front" },
            { src: "/images/product/detail-hook-mechanism.jpg", alt: "Hook mechanism detail" },
          ].map((thumb) => (
            <button
              class="aspect-square rounded-xl bg-neutral-50 border border-neutral-100 overflow-hidden cursor-pointer hover:border-neutral-400 transition-colors focus:ring-2 focus:ring-offset-2 focus:ring-neutral-900 focus:outline-none"
              data-src={thumb.src}
              onclick={`document.querySelector('#main-product-image img').src='${thumb.src}'`}
            >
              <img src={thumb.src} alt={thumb.alt} class="w-full h-full object-cover" loading="lazy" />
            </button>
          ))}
        </div>
      </div>

      <!-- Right: Product Details -->
      <div class="fade-in fade-in-delay-2">
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-xs text-hailth-gray-300 mb-6">
          <a href="/" class="hover:text-hailth-gray-500 transition-colors">Home</a>
          <span>/</span>
          <span class="text-hailth-gray-500">Tactical Belt</span>
        </nav>

        <!-- Product Title -->
        <h1 class="text-3xl lg:text-4xl font-bold text-hailth-black tracking-tight leading-tight">
          HAILTH Tactical<br />Metal Hook Elastic Belt
        </h1>

        <!-- Price -->
        <div class="mt-4 flex items-baseline gap-3">
          <span class="text-3xl font-bold text-hailth-black tracking-tight">$29.99</span>
          <span class="text-sm text-hailth-gray-300 line-through">$49.99</span>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-green-50 text-green-700 border border-green-100">
            Save 40%
          </span>
        </div>

        <!-- Short Description -->
        <p class="mt-6 text-base text-hailth-gray-400 leading-relaxed">
          The belt that adapts to you. High-density elastic webbing with a precision zinc alloy hook buckle delivers infinite adjustability, instant release, and all-day comfort at just 120g.
        </p>

        <!-- Divider -->
        <div class="divider my-8"></div>

        <!-- React Product Selector Island -->
        <ProductSelector client:load />

        <!-- Divider -->
        <div class="divider my-8"></div>

        <!-- Specifications -->
        <div>
          <h4 class="text-sm font-semibold text-hailth-black uppercase tracking-wider mb-6">
            Specifications
          </h4>
          <div class="space-y-0">
            <div class="flex items-start justify-between py-3 border-b border-neutral-100">
              <span class="text-sm text-hailth-gray-400">Material</span>
              <span class="text-sm font-medium text-hailth-black text-right max-w-[60%]">High-density elastic polyester/nylon</span>
            </div>
            <div class="flex items-start justify-between py-3 border-b border-neutral-100">
              <span class="text-sm text-hailth-gray-400">Buckle</span>
              <span class="text-sm font-medium text-hailth-black text-right max-w-[60%]">Zinc alloy metal hook</span>
            </div>
            <div class="flex items-start justify-between py-3 border-b border-neutral-100">
              <span class="text-sm text-hailth-gray-400">Tensile Strength</span>
              <span class="text-sm font-medium text-hailth-black text-right max-w-[60%]">150+ lbs</span>
            </div>
            <div class="flex items-start justify-between py-3 border-b border-neutral-100">
              <span class="text-sm text-hailth-gray-400">Weight</span>
              <span class="text-sm font-medium text-hailth-black text-right max-w-[60%]">120-180g (size dependent)</span>
            </div>
            <div class="flex items-start justify-between py-3 border-b border-neutral-100">
              <span class="text-sm text-hailth-gray-400">Stretch</span>
              <span class="text-sm font-medium text-hailth-black text-right max-w-[60%]">15-25% elastic extension</span>
            </div>
            <div class="flex items-start justify-between py-3 border-b border-neutral-100">
              <span class="text-sm text-hailth-gray-400">Temperature Range</span>
              <span class="text-sm font-medium text-hailth-black text-right max-w-[60%]">-20C to 60C (-4F to 140F)</span>
            </div>
            <div class="flex items-start justify-between py-3 border-b border-neutral-100">
              <span class="text-sm text-hailth-gray-400">Width</span>
              <span class="text-sm font-medium text-hailth-black text-right max-w-[60%]">3.8 cm (1.5 in)</span>
            </div>
            <div class="flex items-start justify-between py-3">
              <span class="text-sm text-hailth-gray-400">Care</span>
              <span class="text-sm font-medium text-hailth-black text-right max-w-[60%]">Hand wash, air dry</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
