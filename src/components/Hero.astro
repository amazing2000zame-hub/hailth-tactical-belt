---
/**
 * Hero Section
 * Full viewport height, dark gradient background with subtle texture.
 * Premium headline, value proposition, CTA to product section.
 */
---

<section
  id="hero"
  class="relative min-h-screen flex items-center justify-center overflow-hidden bg-neutral-950"
>
  <!-- Background gradient layers -->
  <div class="absolute inset-0 bg-gradient-to-br from-neutral-950 via-neutral-900 to-neutral-950"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(200,169,126,0.08),transparent_60%)]"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,rgba(200,169,126,0.04),transparent_50%)]"></div>

  <!-- Subtle grid texture overlay -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left: Copy -->
      <div class="text-center lg:text-left">
        <!-- Eyebrow -->
        <div class="hero-animate opacity-0" style="animation-delay: 0.2s;">
          <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-neutral-700 text-xs font-medium tracking-widest uppercase text-neutral-400 mb-8">
            <span class="w-1.5 h-1.5 rounded-full bg-hailth-gold animate-pulse"></span>
            New Arrival
          </span>
        </div>

        <!-- Headline -->
        <h1 class="hero-animate opacity-0 text-white leading-[0.95] tracking-[-0.04em]" style="animation-delay: 0.35s;">
          Engineered<br />
          for <span class="text-gradient-gold">Every Day</span>
        </h1>

        <!-- Subheadline -->
        <p class="hero-animate opacity-0 mt-6 lg:mt-8 text-lg lg:text-xl text-neutral-400 leading-relaxed max-w-lg mx-auto lg:mx-0" style="animation-delay: 0.5s;">
          The last belt you will ever buy. Infinite adjustability, military-grade construction, zero compromise on comfort.
        </p>

        <!-- CTAs -->
        <div class="hero-animate opacity-0 mt-8 lg:mt-10 flex flex-col sm:flex-row items-center gap-4 justify-center lg:justify-start" style="animation-delay: 0.65s;">
          <a
            href="#product"
            class="group inline-flex items-center justify-center gap-2 px-8 py-4 bg-hailth-gold text-hailth-black text-sm font-semibold tracking-wide uppercase rounded-full transition-all duration-300 hover:bg-hailth-gold-light hover:shadow-[0_4px_24px_rgba(200,169,126,0.3)] hover:-translate-y-0.5 active:translate-y-0"
          >
            Shop Now
            <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5 12 21m0 0-7.5-7.5M12 21V3" />
            </svg>
          </a>
          <a
            href="#features"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 text-sm font-medium tracking-wide uppercase text-neutral-400 border border-neutral-700 rounded-full transition-all duration-300 hover:text-white hover:border-neutral-500 hover:-translate-y-0.5 active:translate-y-0"
          >
            Learn More
          </a>
        </div>

        <!-- Quick stats -->
        <div class="hero-animate opacity-0 mt-12 lg:mt-14 flex items-center gap-8 lg:gap-12 justify-center lg:justify-start" style="animation-delay: 0.8s;">
          <div>
            <div class="text-2xl font-bold text-white tracking-tight">150+</div>
            <div class="text-xs text-neutral-500 uppercase tracking-wider mt-0.5">lbs strength</div>
          </div>
          <div class="w-px h-10 bg-neutral-800"></div>
          <div>
            <div class="text-2xl font-bold text-white tracking-tight">120g</div>
            <div class="text-xs text-neutral-500 uppercase tracking-wider mt-0.5">Ultra Light</div>
          </div>
          <div class="w-px h-10 bg-neutral-800"></div>
          <div>
            <div class="text-2xl font-bold text-white tracking-tight">7</div>
            <div class="text-xs text-neutral-500 uppercase tracking-wider mt-0.5">Colors</div>
          </div>
        </div>
      </div>

      <!-- Right: Product Image Placeholder -->
      <div class="hero-animate opacity-0 relative flex items-center justify-center" style="animation-delay: 0.5s;">
        <div class="relative w-full max-w-md lg:max-w-lg mx-auto">
          <!-- Glow behind product -->
          <div class="absolute inset-0 bg-gradient-to-br from-hailth-gold/10 via-transparent to-hailth-gold/5 rounded-3xl blur-3xl scale-110"></div>

          <!-- Product image container -->
          <div class="relative aspect-square rounded-3xl bg-gradient-to-br from-neutral-800/60 to-neutral-900/80 border border-neutral-800/50 backdrop-blur-sm flex items-center justify-center overflow-hidden">
            <!-- Inner subtle gradient -->
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_30%,rgba(200,169,126,0.06),transparent_60%)]"></div>

            <!-- Placeholder content -->
            <div class="relative text-center p-8">
              <svg class="w-24 h-24 mx-auto text-neutral-700 mb-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="0.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z" />
              </svg>
              <p class="text-sm text-neutral-600 font-medium">Product Image</p>
              <p class="text-xs text-neutral-700 mt-1">Hero shot coming soon</p>
            </div>

            <!-- Corner accent -->
            <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-bl from-hailth-gold/10 to-transparent rounded-bl-3xl"></div>
          </div>

          <!-- Price tag floating -->
          <div class="absolute -bottom-3 -right-3 lg:-bottom-4 lg:-right-4 bg-hailth-gold text-hailth-black px-5 py-2.5 rounded-2xl shadow-lg">
            <div class="text-xs font-medium uppercase tracking-wider opacity-70">From</div>
            <div class="text-xl font-bold tracking-tight">$29.99</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 hero-animate opacity-0" style="animation-delay: 1.2s;">
    <a href="#features" class="flex flex-col items-center gap-2 text-neutral-600 hover:text-neutral-400 transition-colors">
      <span class="text-[10px] uppercase tracking-[0.2em] font-medium">Scroll</span>
      <div class="w-5 h-8 rounded-full border border-neutral-700 flex items-start justify-center p-1">
        <div class="w-1 h-1.5 rounded-full bg-neutral-500 animate-bounce"></div>
      </div>
    </a>
  </div>
</section>

<style>
  @keyframes heroFadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-animate {
    animation: heroFadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>
