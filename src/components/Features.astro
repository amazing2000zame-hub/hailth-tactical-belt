---
/**
 * Features Section
 * Apple-style grid of 4 feature cards with inline SVG icons.
 * Hover effects, clean typography, generous whitespace.
 */

const features = [
  {
    icon: "infinite-adjust",
    title: "Infinite Adjustability",
    description: "No holes, no limits. The elastic webbing and metal hook system lets you dial in the exact fit, every single time.",
  },
  {
    icon: "quick-release",
    title: "Quick Release",
    description: "One-handed hook release for fast on and off. Engineered for speed when every second counts.",
  },
  {
    icon: "military-grade",
    title: "Military Grade",
    description: "150+ lbs tensile strength with zinc alloy buckle. Built to endure extreme conditions from -20 to 60 Celsius.",
  },
  {
    icon: "ultra-light",
    title: "Ultra Light",
    description: "At just 120-180g, you will forget it is there. High-density elastic polyester and nylon that moves with your body.",
  },
];
---

<section id="features" class="section bg-hailth-white">
  <div class="container-content">
    <!-- Section header -->
    <div class="text-center max-w-2xl mx-auto mb-16 lg:mb-20">
      <h6 class="fade-in text-hailth-gold-dark !text-hailth-gold-dark">Why HAILTH</h6>
      <h2 class="fade-in fade-in-delay-1 mt-4">
        Built Different.<br />
        <span class="text-gradient-gold">Worn Better.</span>
      </h2>
      <p class="fade-in fade-in-delay-2 mt-6 text-base lg:text-lg mx-auto">
        Every detail obsessively engineered. From the elastic weave to the zinc alloy hook, nothing is left to chance.
      </p>
    </div>

    <!-- Feature grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
      {features.map((feature, i) => (
        <div class={`fade-in fade-in-delay-${i + 1} group relative p-8 lg:p-10 rounded-2xl bg-white border border-neutral-100 transition-all duration-500 hover:border-neutral-200 hover:shadow-[0_8px_30px_rgba(0,0,0,0.06)] hover:-translate-y-1`}>
          <!-- Icon -->
          <div class="w-12 h-12 rounded-xl bg-neutral-50 border border-neutral-100 flex items-center justify-center mb-6 transition-all duration-500 group-hover:bg-hailth-gold/10 group-hover:border-hailth-gold/20">
            {feature.icon === "infinite-adjust" && (
              <svg class="w-6 h-6 text-hailth-gray-500 transition-colors duration-500 group-hover:text-hailth-gold-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
              </svg>
            )}
            {feature.icon === "quick-release" && (
              <svg class="w-6 h-6 text-hailth-gray-500 transition-colors duration-500 group-hover:text-hailth-gold-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" />
              </svg>
            )}
            {feature.icon === "military-grade" && (
              <svg class="w-6 h-6 text-hailth-gray-500 transition-colors duration-500 group-hover:text-hailth-gold-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
              </svg>
            )}
            {feature.icon === "ultra-light" && (
              <svg class="w-6 h-6 text-hailth-gray-500 transition-colors duration-500 group-hover:text-hailth-gold-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
              </svg>
            )}
          </div>

          <!-- Title -->
          <h4 class="text-lg font-semibold text-hailth-black tracking-tight mb-3">
            {feature.title}
          </h4>

          <!-- Description -->
          <p class="text-sm text-hailth-gray-400 leading-relaxed">
            {feature.description}
          </p>

          <!-- Hover accent line -->
          <div class="absolute bottom-0 left-8 right-8 h-0.5 bg-gradient-to-r from-transparent via-hailth-gold to-transparent rounded-full opacity-0 transition-opacity duration-500 group-hover:opacity-40"></div>
        </div>
      ))}
    </div>

    <!-- Bottom stat bar -->
    <div class="mt-16 lg:mt-20 py-8 px-8 lg:px-12 rounded-2xl bg-neutral-950 text-white">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 text-center">
        <div>
          <div class="text-2xl lg:text-3xl font-bold tracking-tight text-gradient-gold">15-25%</div>
          <div class="text-xs text-neutral-400 uppercase tracking-wider mt-1">Elastic Stretch</div>
        </div>
        <div>
          <div class="text-2xl lg:text-3xl font-bold tracking-tight text-gradient-gold">28"-50"</div>
          <div class="text-xs text-neutral-400 uppercase tracking-wider mt-1">Size Range</div>
        </div>
        <div>
          <div class="text-2xl lg:text-3xl font-bold tracking-tight text-gradient-gold">-20/60</div>
          <div class="text-xs text-neutral-400 uppercase tracking-wider mt-1">Temp Range (C)</div>
        </div>
        <div>
          <div class="text-2xl lg:text-3xl font-bold tracking-tight text-gradient-gold">5</div>
          <div class="text-xs text-neutral-400 uppercase tracking-wider mt-1">Year Warranty</div>
        </div>
      </div>
    </div>
  </div>
</section>
