---
/**
 * Trust Badges
 * Horizontal bar of trust signals on dark background.
 * Free Shipping, 30-Day Returns, Secure Checkout, 1-Year Warranty.
 */
---

<section class="trust-badges">
  <div class="container-content">
    <div class="trust-badges__grid">
      <!-- Free Shipping -->
      <div class="trust-badges__item">
        <div class="trust-badges__icon-wrap">
          <svg class="trust-badges__icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
          </svg>
        </div>
        <div>
          <p class="trust-badges__title">Free Shipping</p>
          <p class="trust-badges__subtitle">On every order</p>
        </div>
      </div>

      <!-- 30-Day Returns -->
      <div class="trust-badges__item">
        <div class="trust-badges__icon-wrap">
          <svg class="trust-badges__icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 15L3 9m0 0l6-6M3 9h12a6 6 0 010 12h-3" />
          </svg>
        </div>
        <div>
          <p class="trust-badges__title">30-Day Returns</p>
          <p class="trust-badges__subtitle">Hassle-free</p>
        </div>
      </div>

      <!-- Secure Checkout -->
      <div class="trust-badges__item">
        <div class="trust-badges__icon-wrap">
          <svg class="trust-badges__icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
          </svg>
        </div>
        <div>
          <p class="trust-badges__title">Secure Checkout</p>
          <p class="trust-badges__subtitle">SSL encrypted</p>
        </div>
      </div>

      <!-- 1-Year Warranty -->
      <div class="trust-badges__item">
        <div class="trust-badges__icon-wrap">
          <svg class="trust-badges__icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
          </svg>
        </div>
        <div>
          <p class="trust-badges__title">1-Year Warranty</p>
          <p class="trust-badges__subtitle">Full coverage</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .trust-badges {
    background-color: var(--color-hailth-black);
    padding: 3rem 0;
  }

  .trust-badges__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .trust-badges__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 3rem;
    }
  }

  .trust-badges__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.75rem;
  }

  .trust-badges__icon-wrap {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background var(--duration-normal) var(--ease-smooth);
  }

  .trust-badges__item:hover .trust-badges__icon-wrap {
    background: rgba(200, 169, 126, 0.15);
  }

  .trust-badges__icon {
    width: 20px;
    height: 20px;
    color: var(--color-hailth-white);
  }

  .trust-badges__title {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-hailth-white);
    max-width: none;
  }

  .trust-badges__subtitle {
    font-size: 0.6875rem;
    color: var(--color-hailth-gray-400);
    margin-top: 2px;
    max-width: none;
  }
</style>
