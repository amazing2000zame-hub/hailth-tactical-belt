---
/**
 * Footer Component
 * Dark, organized grid layout with links, legal, and social.
 */
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <!-- Top divider -->
  <div class="divider"></div>

  <div class="footer__inner container-content">
    <!-- Upper section: Brand + Link columns -->
    <div class="footer__grid">
      <!-- Brand Column -->
      <div class="footer__brand">
        <a href="/" class="footer__logo">HAILTH</a>
        <p class="footer__tagline">
          Engineered for those who carry everything&mdash;and never compromise.
        </p>
      </div>

      <!-- Shop Column -->
      <div class="footer__col">
        <h4 class="footer__heading">Shop</h4>
        <ul class="footer__list">
          <li><a href="/product" class="footer__link">Tactical Belt</a></li>
          <li><a href="/product#features" class="footer__link">Features</a></li>
          <li><a href="/product#specs" class="footer__link">Specifications</a></li>
        </ul>
      </div>

      <!-- Company Column -->
      <div class="footer__col">
        <h4 class="footer__heading">Company</h4>
        <ul class="footer__list">
          <li><a href="/about" class="footer__link">About</a></li>
          <li><a href="/faq" class="footer__link">FAQ</a></li>
          <li><a href="/contact" class="footer__link">Contact</a></li>
        </ul>
      </div>

      <!-- Legal Column -->
      <div class="footer__col">
        <h4 class="footer__heading">Legal</h4>
        <ul class="footer__list">
          <li><a href="/privacy" class="footer__link">Privacy Policy</a></li>
          <li><a href="/terms" class="footer__link">Terms of Service</a></li>
          <li><a href="/shipping" class="footer__link">Shipping & Returns</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar: Copyright + Social -->
    <div class="footer__bottom">
      <p class="footer__copyright">
        &copy; {currentYear} HAILTH. All rights reserved.
      </p>

      <div class="footer__social">
        <!-- Instagram -->
        <a href="#" class="footer__social-link" aria-label="Instagram" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
        </a>
        <!-- X / Twitter -->
        <a href="#" class="footer__social-link" aria-label="X (Twitter)" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
        <!-- TikTok -->
        <a href="#" class="footer__social-link" aria-label="TikTok" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86 4.46V13.2a8.19 8.19 0 005.58 2.18V12a4.77 4.77 0 01-3.77-1.54V6.69h3.77z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-hailth-black);
    color: var(--color-hailth-gray-300);
    padding-top: 0;
  }

  .footer__inner {
    padding-top: 4rem;
    padding-bottom: 2rem;
  }

  /* ---- Grid Layout ---- */
  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--color-hailth-gray-700);
  }

  @media (min-width: 640px) {
    .footer__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 768px) {
    .footer__grid {
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 3rem;
    }
  }

  /* ---- Brand ---- */
  .footer__logo {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--color-hailth-white);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 1rem;
    transition: opacity var(--duration-normal) var(--ease-smooth);
  }

  .footer__logo:hover {
    opacity: 0.7;
    color: var(--color-hailth-white);
  }

  .footer__tagline {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-hailth-gray-400);
    max-width: 280px;
  }

  /* ---- Columns ---- */
  .footer__heading {
    font-family: var(--font-display);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-hailth-gray-300);
    margin-bottom: 1.25rem;
  }

  .footer__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer__link {
    font-size: 0.8125rem;
    color: var(--color-hailth-gray-400);
    text-decoration: none;
    transition: color var(--duration-normal) var(--ease-smooth);
  }

  .footer__link:hover {
    color: var(--color-hailth-white);
  }

  /* ---- Bottom Bar ---- */
  .footer__bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    padding-top: 2rem;
  }

  @media (min-width: 640px) {
    .footer__bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .footer__copyright {
    font-size: 0.75rem;
    color: var(--color-hailth-gray-500);
    letter-spacing: 0.02em;
  }

  /* ---- Social Links ---- */
  .footer__social {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    color: var(--color-hailth-gray-400);
    border: 1px solid var(--color-hailth-gray-700);
    border-radius: 50%;
    transition: color var(--duration-normal) var(--ease-smooth),
                border-color var(--duration-normal) var(--ease-smooth),
                background var(--duration-normal) var(--ease-smooth);
  }

  .footer__social-link:hover {
    color: var(--color-hailth-white);
    border-color: var(--color-hailth-gray-500);
    background: var(--color-hailth-black-soft);
  }
</style>
