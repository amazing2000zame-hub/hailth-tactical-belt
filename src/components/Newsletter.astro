---
/**
 * Newsletter Section
 * Email signup with 10% off incentive. Dark background section
 * placed above footer for maximum visibility.
 */
---

<section class="newsletter">
  <div class="container-content">
    <div class="newsletter__inner">
      <!-- Badge -->
      <div class="newsletter__badge">
        <svg class="newsletter__badge-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" />
        </svg>
        10% off your first order
      </div>

      <!-- Heading -->
      <h2 class="newsletter__heading">Join the HAILTH Community</h2>
      <p class="newsletter__text">
        Get early access to new products, exclusive discounts, and gear tips delivered to your inbox. Subscribe now and save 10% on your first order.
      </p>

      <!-- Form -->
      <form class="newsletter__form" action="#" method="POST">
        <label for="newsletter-email" class="sr-only">Email address</label>
        <input
          type="email"
          id="newsletter-email"
          name="email"
          required
          placeholder="Enter your email"
          class="newsletter__input"
        />
        <button type="submit" class="newsletter__btn">
          Subscribe
        </button>
      </form>

      <!-- Privacy note -->
      <p class="newsletter__privacy">
        No spam, ever. Unsubscribe anytime. By subscribing you agree to our
        <a href="#" class="newsletter__privacy-link">Privacy Policy</a>.
      </p>
    </div>
  </div>
</section>

<style>
  .newsletter {
    background: var(--color-hailth-black);
    padding: 6rem 0;
  }

  @media (min-width: 768px) {
    .newsletter {
      padding: 8rem 0;
    }
  }

  .newsletter__inner {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
  }

  /* ---- Badge ---- */
  .newsletter__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 6px 16px;
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.08);
    color: var(--color-hailth-white);
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    margin-bottom: 2rem;
  }

  .newsletter__badge-icon {
    width: 14px;
    height: 14px;
  }

  /* ---- Heading + Text ---- */
  .newsletter__heading {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw + 0.5rem, 2.5rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    color: var(--color-hailth-white);
    line-height: 1.15;
  }

  .newsletter__text {
    margin-top: 1rem;
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-hailth-gray-400);
    max-width: none;
  }

  /* ---- Form ---- */
  .newsletter__form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 2.5rem;
    max-width: 420px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (min-width: 480px) {
    .newsletter__form {
      flex-direction: row;
    }
  }

  .newsletter__input {
    flex: 1;
    padding: 0.875rem 1.25rem;
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--color-hailth-white);
    font-family: var(--font-body);
    font-size: 0.875rem;
    outline: none;
    transition: all var(--duration-normal) var(--ease-smooth);
  }

  .newsletter__input::placeholder {
    color: var(--color-hailth-gray-500);
  }

  .newsletter__input:focus {
    border-color: rgba(200, 169, 126, 0.4);
    background: rgba(255, 255, 255, 0.12);
  }

  .newsletter__btn {
    padding: 0.875rem 2rem;
    border-radius: var(--radius-pill);
    background: var(--color-hailth-gold);
    color: var(--color-hailth-black);
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    transition: all var(--duration-normal) var(--ease-smooth);
  }

  .newsletter__btn:hover {
    background: var(--color-hailth-gold-light);
    transform: translateY(-1px);
    box-shadow: var(--shadow-gold);
  }

  .newsletter__btn:active {
    transform: translateY(0);
  }

  /* ---- Privacy ---- */
  .newsletter__privacy {
    margin-top: 1rem;
    font-size: 0.6875rem;
    color: var(--color-hailth-gray-500);
    max-width: none;
  }

  .newsletter__privacy-link {
    text-decoration: underline;
    text-underline-offset: 2px;
    color: var(--color-hailth-gray-400);
    transition: color var(--duration-normal) var(--ease-smooth);
  }

  .newsletter__privacy-link:hover {
    color: var(--color-hailth-white);
  }

  /* Screen reader only */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
