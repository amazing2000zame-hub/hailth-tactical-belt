---
/**
 * Success Page
 * Shown after successful Stripe checkout completion.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Order Confirmed | HAILTH" description="Thank you for your purchase. Your HAILTH tactical belt is on its way.">

  <section class="section">
    <div class="container-content">
      <div class="success">
        <div class="success__icon-wrap fade-in">
          <svg class="success__icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>

        <h1 class="success__heading fade-in fade-in-delay-1">Order Confirmed</h1>
        <p class="success__text fade-in fade-in-delay-2">
          Thank you for your purchase. Your HAILTH tactical belt is being prepared for shipment.
          You'll receive a confirmation email with tracking details shortly.
        </p>

        <div class="success__details fade-in fade-in-delay-3">
          <div class="success__detail-row">
            <svg class="success__detail-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
            <span>Confirmation email sent to your inbox</span>
          </div>
          <div class="success__detail-row">
            <svg class="success__detail-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
            </svg>
            <span>Ships within 1-2 business days</span>
          </div>
        </div>

        <a href="/" class="success__cta btn-primary fade-in fade-in-delay-3">
          Continue Shopping
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  // Clear cart session after successful checkout
  localStorage.removeItem('hailth_cart_session');
  window.dispatchEvent(new CustomEvent('cart-updated', {
    detail: { sessionId: '', items: [], total: 0, itemCount: 0 }
  }));
</script>

<style>
  .success {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
    padding: 4rem 0;
  }

  .success__icon-wrap {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: #f0fdf4;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .success__icon {
    width: 48px;
    height: 48px;
    color: #16a34a;
  }

  .success__heading {
    font-size: clamp(2rem, 4vw + 0.5rem, 2.75rem);
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }

  .success__text {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-hailth-gray-400);
    max-width: none;
    margin-bottom: 2.5rem;
  }

  .success__details {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 3rem;
    width: 100%;
    max-width: 360px;
  }

  .success__detail-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.875rem;
    color: var(--color-hailth-gray-500);
  }

  .success__detail-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    color: var(--color-hailth-gray-400);
  }

  .success__cta {
    text-decoration: none;
  }
</style>
