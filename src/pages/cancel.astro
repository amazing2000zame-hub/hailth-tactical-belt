---
/**
 * Cancel Page
 * Shown when user cancels Stripe checkout.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Order Cancelled | HAILTH" description="Your checkout was cancelled. Your cart items are still saved.">

  <section class="section">
    <div class="container-content">
      <div class="cancel">
        <div class="cancel__icon-wrap fade-in">
          <svg class="cancel__icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 9.75l4.5 4.5m0-4.5l-4.5 4.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>

        <h1 class="cancel__heading fade-in fade-in-delay-1">Checkout Cancelled</h1>
        <p class="cancel__text fade-in fade-in-delay-2">
          No worries -- your cart items are still saved. You can return to your cart
          whenever you're ready to complete your purchase.
        </p>

        <div class="cancel__actions fade-in fade-in-delay-3">
          <a href="/cart" class="btn-primary cancel__cta">
            Return to Cart
          </a>
          <a href="/" class="cancel__link">
            Continue Shopping
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .cancel {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
    padding: 4rem 0;
  }

  .cancel__icon-wrap {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: #fef2f2;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .cancel__icon {
    width: 48px;
    height: 48px;
    color: #dc2626;
  }

  .cancel__heading {
    font-size: clamp(2rem, 4vw + 0.5rem, 2.75rem);
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }

  .cancel__text {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-hailth-gray-400);
    max-width: none;
    margin-bottom: 3rem;
  }

  .cancel__actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .cancel__cta {
    text-decoration: none;
  }

  .cancel__link {
    font-size: 0.875rem;
    color: var(--color-hailth-gray-400);
    text-decoration: none;
    transition: color var(--duration-normal) var(--ease-smooth);
  }

  .cancel__link:hover {
    color: var(--color-hailth-gold);
  }
</style>
