---
/**
 * Shipping & Returns Page
 * Comprehensive shipping, return, and warranty policies.
 * Clear step-by-step return process.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Shipping & Returns | HAILTH" description="Free shipping on all orders. 30-day hassle-free returns. Learn about HAILTH shipping times, return process, and warranty.">

  <section class="section">
    <div class="container-narrow">

      <!-- Header -->
      <div class="mb-16">
        <h6 class="fade-in text-hailth-gold-dark !text-hailth-gold-dark">Policies</h6>
        <h1 class="fade-in fade-in-delay-1 mt-4 shipping__heading">
          Shipping & Returns
        </h1>
        <p class="fade-in fade-in-delay-2 mt-6 shipping__subtitle">
          Free shipping worldwide. Easy returns. No fine print.
        </p>
      </div>

      <div class="shipping__sections">

        <!-- Shipping -->
        <div class="fade-in">
          <h2 class="shipping__section-title">
            <span class="shipping__section-icon-wrap">
              <svg class="shipping__section-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
              </svg>
            </span>
            Shipping
          </h2>

          <div class="shipping__options">
            <div class="shipping__option">
              <span class="shipping__dot shipping__dot--green"></span>
              <div>
                <p class="shipping__option-title">Free Standard Shipping</p>
                <p class="shipping__option-desc">7-15 business days delivery worldwide. No minimum order required.</p>
              </div>
            </div>
            <div class="shipping__option">
              <span class="shipping__dot shipping__dot--blue"></span>
              <div>
                <p class="shipping__option-title">DHL Express (optional)</p>
                <p class="shipping__option-desc">3-5 business days delivery. Available at checkout for an additional fee. Includes full tracking and signature confirmation.</p>
              </div>
            </div>
          </div>

          <div class="shipping__body">
            <h3 class="shipping__sub-title">Processing Time</h3>
            <p class="shipping__text">
              All orders are processed within 1-3 business days. You'll receive a confirmation email with tracking information once your order ships. Orders placed on weekends or holidays will be processed the next business day.
            </p>

            <h3 class="shipping__sub-title">Tracking</h3>
            <p class="shipping__text">
              Every order includes a tracking number sent to your email. You can use this number to monitor your shipment's progress in real-time through our shipping partner's website.
            </p>

            <h3 class="shipping__sub-title">International Shipping</h3>
            <p class="shipping__text">
              We ship to most countries worldwide. Please note that international orders may be subject to customs duties and import taxes imposed by your country's government. These charges are the responsibility of the buyer and are not included in the item price or shipping cost.
            </p>
          </div>
        </div>

        <!-- Divider -->
        <div class="divider"></div>

        <!-- Returns -->
        <div class="fade-in">
          <h2 class="shipping__section-title">
            <span class="shipping__section-icon-wrap">
              <svg class="shipping__section-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 15L3 9m0 0l6-6M3 9h12a6 6 0 010 12h-3" />
              </svg>
            </span>
            Returns
          </h2>

          <div class="shipping__body">
            <p class="shipping__text">
              We want you to love your HAILTH belt. If for any reason you're not completely satisfied, we offer a <strong>30-day hassle-free return policy</strong> from the date of delivery.
            </p>

            <h3 class="shipping__sub-title">Return Conditions</h3>
            <ul class="shipping__list">
              <li>Item must be in original, unworn condition</li>
              <li>Original packaging must be included</li>
              <li>Trimmed belts can still be returned (we understand you need to try it on)</li>
              <li>Return request must be made within 30 days of delivery</li>
            </ul>

            <h3 class="shipping__sub-title">How to Return</h3>
          </div>

          <!-- Return Steps -->
          <div class="shipping__steps">
            <div class="shipping__step">
              <span class="shipping__step-num">1</span>
              <p class="shipping__step-title">Contact Us</p>
              <p class="shipping__step-desc">Email support@hailth.com with your order number</p>
            </div>
            <div class="shipping__step">
              <span class="shipping__step-num">2</span>
              <p class="shipping__step-title">Ship It Back</p>
              <p class="shipping__step-desc">We'll provide a prepaid return shipping label</p>
            </div>
            <div class="shipping__step">
              <span class="shipping__step-num">3</span>
              <p class="shipping__step-title">Get Refunded</p>
              <p class="shipping__step-desc">Full refund within 5-7 business days of receiving the return</p>
            </div>
          </div>
        </div>

        <!-- Divider -->
        <div class="divider"></div>

        <!-- Warranty -->
        <div class="fade-in">
          <h2 class="shipping__section-title">
            <span class="shipping__section-icon-wrap">
              <svg class="shipping__section-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
              </svg>
            </span>
            Warranty
          </h2>

          <div class="shipping__body">
            <p class="shipping__text">
              Every HAILTH belt is backed by a <strong>1-year warranty</strong> against manufacturing defects. This covers:
            </p>

            <ul class="shipping__list">
              <li>Buckle mechanism failure or malfunction</li>
              <li>Premature strap fraying or delamination</li>
              <li>Hardware loosening or detachment</li>
              <li>Stitching failure under normal use</li>
            </ul>

            <p class="shipping__text">
              Normal wear and tear from extended daily use is not covered. To make a warranty claim, email
              <a href="mailto:support@hailth.com" class="shipping__link">support@hailth.com</a>
              with your order number and photos of the defect.
            </p>
          </div>
        </div>
      </div>

      <!-- Contact CTA -->
      <div class="shipping__cta">
        <p class="shipping__cta-text">
          Have a question about shipping or returns?
          <a href="/contact" class="shipping__link">Contact our team</a>
          and we'll respond within 24 hours.
        </p>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .shipping__heading {
    font-size: clamp(2rem, 4vw + 0.5rem, 3.25rem);
    line-height: 1.1;
  }

  .shipping__subtitle {
    font-size: 1.125rem;
    color: var(--color-hailth-gray-400);
    max-width: none;
  }

  .shipping__sections {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  /* ---- Section Titles ---- */
  .shipping__section-title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
  }

  .shipping__section-icon-wrap {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-md);
    background: var(--color-hailth-gray-50);
    border: 1px solid var(--color-hailth-gray-100);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .shipping__section-icon {
    width: 20px;
    height: 20px;
    color: var(--color-hailth-gray-500);
  }

  .shipping__sub-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-hailth-black);
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    line-height: 1.4;
    letter-spacing: -0.01em;
  }

  /* ---- Body Content ---- */
  .shipping__body {
    margin-top: 0.5rem;
  }

  .shipping__text {
    font-size: 0.9375rem;
    line-height: 1.8;
    color: var(--color-hailth-gray-400);
    max-width: none;
    margin-top: 0.5rem;
  }

  .shipping__text strong {
    color: var(--color-hailth-black);
    font-weight: 600;
  }

  .shipping__list {
    list-style: none;
    padding: 0;
    margin: 0.75rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .shipping__list li {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-hailth-gray-400);
    padding-left: 1.5rem;
    position: relative;
  }

  .shipping__list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-hailth-gray-300);
  }

  /* ---- Shipping Options ---- */
  .shipping__options {
    background: var(--color-hailth-gray-50);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 1rem;
  }

  .shipping__option {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .shipping__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 6px;
  }

  .shipping__dot--green {
    background: var(--color-hailth-trust);
  }

  .shipping__dot--blue {
    background: #007aff;
  }

  .shipping__option-title {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-hailth-black);
    max-width: none;
  }

  .shipping__option-desc {
    font-size: 0.8125rem;
    color: var(--color-hailth-gray-400);
    line-height: 1.6;
    margin-top: 0.25rem;
    max-width: none;
  }

  /* ---- Return Steps ---- */
  .shipping__steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  @media (min-width: 640px) {
    .shipping__steps {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .shipping__step {
    background: var(--color-hailth-gray-50);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    text-align: center;
  }

  .shipping__step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--color-hailth-black);
    color: var(--color-hailth-white);
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .shipping__step-title {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-hailth-black);
    max-width: none;
  }

  .shipping__step-desc {
    font-size: 0.75rem;
    color: var(--color-hailth-gray-400);
    line-height: 1.5;
    margin-top: 0.25rem;
    max-width: none;
  }

  /* ---- Link ---- */
  .shipping__link {
    font-weight: 600;
    color: var(--color-hailth-black);
    text-decoration: underline;
    text-underline-offset: 4px;
    transition: color var(--duration-normal) var(--ease-smooth);
  }

  .shipping__link:hover {
    color: var(--color-hailth-gold);
  }

  /* ---- CTA ---- */
  .shipping__cta {
    margin-top: 4rem;
    padding-top: 4rem;
    border-top: 1px solid var(--color-hailth-gray-200);
    text-align: center;
  }

  .shipping__cta-text {
    font-size: 0.875rem;
    color: var(--color-hailth-gray-400);
    max-width: none;
    margin: 0 auto;
  }
</style>
