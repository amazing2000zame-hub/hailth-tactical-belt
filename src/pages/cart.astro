---
import BaseLayout from "../layouts/BaseLayout.astro";
import CartPage from "../components/CartPage.tsx";
---

<BaseLayout
  title="Your Cart | HAILTH"
  description="Review your cart and proceed to checkout."
>
  <section class="cart-page">
    <div class="container-narrow">
      <!-- Breadcrumb -->
      <nav class="cart-page__breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <span>Cart</span>
      </nav>

      <h1 class="cart-page__title">Your Cart</h1>

      <!-- React cart island -->
      <div id="cart-content">
        <CartPage client:load />
      </div>

      <!-- Empty state (shown when cart is empty via JS) -->
      <div class="cart-page__empty" id="cart-empty">
        <div class="cart-page__empty-icon">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"></path>
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <path d="M16 10a4 4 0 01-8 0"></path>
          </svg>
        </div>
        <h2 class="cart-page__empty-heading">Your cart is empty</h2>
        <p class="cart-page__empty-text">
          Looks like you haven't added the HAILTH Tactical Belt yet.
        </p>
        <a href="/product" class="cart-page__shop-btn">
          Shop Now
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </a>
      </div>

      <!-- Trust row -->
      <div class="cart-page__trust">
        <div class="cart-page__trust-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"></path>
          </svg>
          <span>Secure Checkout</span>
        </div>
        <div class="cart-page__trust-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 15L3 9m0 0l6-6M3 9h12a6 6 0 010 12h-3"></path>
          </svg>
          <span>30-Day Returns</span>
        </div>
        <div class="cart-page__trust-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"></path>
          </svg>
          <span>Free Shipping</span>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Toggle empty state based on cart content
  function updateEmptyState() {
    const empty = document.getElementById('cart-empty');
    const sid = localStorage.getItem('hailth_cart_session');
    if (!sid) {
      if (empty) empty.style.display = '';
      return;
    }
    // Check the API for cart items
    fetch(`http://localhost:4322/api/cart/${sid}`)
      .then(r => r.ok ? r.json() : null)
      .then(cart => {
        if (empty) {
          empty.style.display = (cart && cart.itemCount > 0) ? 'none' : '';
        }
      })
      .catch(() => {
        if (empty) empty.style.display = '';
      });
  }

  updateEmptyState();
  window.addEventListener('cart-updated', (e: any) => {
    const empty = document.getElementById('cart-empty');
    if (empty) {
      empty.style.display = (e.detail && e.detail.itemCount > 0) ? 'none' : '';
    }
  });
</script>

<style>
  .cart-page {
    padding: 2rem 0 6rem;
    min-height: 60vh;
  }

  .cart-page__breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: var(--color-hailth-gray-300);
    margin-bottom: 2rem;
  }

  .cart-page__breadcrumb a {
    color: var(--color-hailth-gray-300);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .cart-page__breadcrumb a:hover {
    color: var(--color-hailth-gray-500);
  }

  .cart-page__breadcrumb span:last-child {
    color: var(--color-hailth-gray-500);
  }

  .cart-page__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 600;
    color: var(--color-hailth-black);
    letter-spacing: -0.03em;
    margin-bottom: 3rem;
  }

  /* Empty state */
  .cart-page__empty {
    text-align: center;
    padding: 4rem 0;
  }

  .cart-page__empty-icon {
    color: var(--color-hailth-gray-200);
    margin-bottom: 1.5rem;
  }

  .cart-page__empty-heading {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-hailth-black);
    margin-bottom: 0.75rem;
  }

  .cart-page__empty-text {
    font-size: 0.9375rem;
    color: var(--color-hailth-gray-400);
    max-width: 320px;
    margin: 0 auto 2rem;
    line-height: 1.6;
  }

  .cart-page__shop-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 2rem;
    border-radius: var(--radius-pill);
    background: var(--color-hailth-black);
    color: var(--color-hailth-white);
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .cart-page__shop-btn:hover {
    background: var(--color-hailth-gold);
    color: var(--color-hailth-black);
    transform: translateY(-1px);
  }

  /* Trust badges */
  .cart-page__trust {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-hailth-gray-100);
  }

  .cart-page__trust-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: var(--color-hailth-gray-400);
    font-weight: 500;
  }

  .cart-page__trust-item svg {
    color: var(--color-hailth-gray-300);
  }

  @media (max-width: 640px) {
    .cart-page__trust {
      flex-direction: column;
      align-items: center;
      gap: 1rem;
    }
  }
</style>
